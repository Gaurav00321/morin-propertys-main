# ═══════════════════════════════════════════════════
# MORIN PROPERTY — Environment Variables Template
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ═══════════════════════════════════════════════════

# GOOGLE ANALYTICS 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# GOOGLE MAPS (optional — uses iframe embeds by default)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# RESEND EMAIL — Get from resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL=morincontact@gmail.com

# WHATSAPP
WHATSAPP_NUMBER=919376786108
NEXT_PUBLIC_WHATSAPP_NUMBER=919376786108

# SITE
NEXT_PUBLIC_SITE_URL=https://www.morinpropertys.com
NEXT_PUBLIC_SITE_NAME=Morin Property
NEXT_PUBLIC_PHONE=+91-9376786108

# SUPABASE (Database & Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ADMIN ACCESS
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password
